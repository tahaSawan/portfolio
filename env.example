# Public site URL (no trailing slash). Used for Open Graph, Twitter cards, sitemap, and robots.
NEXT_PUBLIC_SITE_URL=https://example.com

# Groq API key for the portfolio assistant (server-side only — get one free at https://console.groq.com).
# Copy to .env.local for local dev; set in Vercel → Settings → Environment Variables for production.
GROQ_API_KEY=
